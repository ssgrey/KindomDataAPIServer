<dx:ThemedWindow
    x:Class="KindomDataAPIServer.Views.AdvancedSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:KindomDataAPIServer.Converters"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    Title="Advanced Settings"
    Width="460"
    Height="520"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <dx:ThemedWindow.Resources>
        <converters:DecimalToIntConverter x:Key="DecimalToIntConverter" />
    </dx:ThemedWindow.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical">
                <GroupBox Header="Well Header" Margin="0,0,0,8">
                    <StackPanel Margin="8,4,8,8">
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Batch Size" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="1000000"
                                IsFloatValue="False"
                                EditValue="{Binding WellHeaderBatchSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Well Trajectory" Margin="0,0,0,8">
                    <StackPanel Margin="8,4,8,8">
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Batch Size" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="1000000"
                                IsFloatValue="False"
                                EditValue="{Binding WellTrajectoryBatchSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Upload Concurrency" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="100"
                                IsFloatValue="False"
                                EditValue="{Binding WellTrajectoryUploadConcurrency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Well Log" Margin="0,0,0,8">
                    <StackPanel Margin="8,4,8,8">
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Upload Concurrency" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="100"
                                IsFloatValue="False"
                                EditValue="{Binding WellLogUploadConcurrency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Batch Curve Count" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="1000000"
                                IsFloatValue="False"
                                EditValue="{Binding WellLogBatchCurveCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Well Production" Margin="0,0,0,8">
                    <StackPanel Margin="8,4,8,8">
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Upload Concurrency" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="100"
                                IsFloatValue="False"
                                EditValue="{Binding WellProductionUploadConcurrency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Batch Daily Data Count" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="1000000"
                                IsFloatValue="False"
                                EditValue="{Binding WellProductionBatchDailyDataCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Well Formation" Margin="0,0,0,8">
                    <StackPanel Margin="8,4,8,8">
                        <StackPanel Height="32" Orientation="Horizontal">
                            <Label
                                Width="220"
                                VerticalAlignment="Center"
                                Content="Batch Size" />
                            <dxe:SpinEdit
                                Width="120"
                                Height="25"
                                MinValue="1"
                                MaxValue="1000000"
                                IsFloatValue="False"
                                EditValue="{Binding WellFormationBatchSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToIntConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <StackPanel
            Grid.Row="1"
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <dx:SimpleButton
                Width="80"
                Height="26"
                Margin="0,0,8,0"
                Click="Ok_Click"
                Content="OK" />
            <dx:SimpleButton
                Width="80"
                Height="26"
                Click="Cancel_Click"
                Content="Cancel" />
        </StackPanel>
    </Grid>
</dx:ThemedWindow>
